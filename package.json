{
  "name": "grafana-nocodb-datasource",
  "version": "1.0.0",
  "description": "Enterprise-ready Grafana datasource plugin for NocoDB",
  "scripts": {
    "build": "webpack -c webpack.config.ts --env production",
    "dev": "webpack -w -c webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "backend:build": "mage -v build:linux",
    "backend:test": "go test -v ./pkg/...",
    "backend:coverage": "go test -v -cover -coverprofile=coverage.out ./pkg/..."
  },
  "author": "Your Organization",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@grafana/eslint-config": "^7.0.0",
    "@grafana/tsconfig": "^1.3.0",
    "@playwright/test": "^1.42.0",
    "@swc/core": "^1.4.8",
    "@swc/helpers": "^0.5.6",
    "@swc/jest": "^0.2.36",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.25",
    "@types/react": "^18.2.64",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-webpack-plugin": "^4.0.1",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "glob": "^10.3.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.71.1",
    "sass-loader": "^14.1.1",
    "style-loader": "^3.3.4",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2"
  },
  "dependencies": {
    "@grafana/data": "^11.0.0",
    "@grafana/runtime": "^11.0.0",
    "@grafana/ui": "^11.0.0",
    "@emotion/css": "^11.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tslib": "^2.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
