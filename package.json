    "@testing-library/react": "^14.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "style-loader": "^3.3.4",
    "swc-loader": "^0.2.6",
